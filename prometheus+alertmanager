defaultRules:
  create: false

admissionWebhooks:
  enabled: false
  patch:
    enabled: false
  create:
    enabled: false
  certManager:
    enabled: false

tls:
  enabled: false

prometheus:
  prometheusSpec:
    retention: 14d

    nodeSelector:
      kubernetes.io/hostname: zddwmsprowork1

    storageSpec:
      volumeClaimTemplate:
        spec:
          storageClassName: ""   # ⚠ change based on your cluster
          accessModes:
            - ReadWriteOnce
          resources:
            requests:
              storage: 50Gi

    serviceMonitorSelectorNilUsesHelmValues: false
    podMonitorSelectorNilUsesHelmValues: false

    additionalScrapeConfigs:
      - job_name: "blackbox-https"
        metrics_path: /probe
        scrape_interval: 30s
        params:
          module:
            - http_concinity_ui
        static_configs:
          - targets:
              - https://zd-asrs-prod.zyduslife.com/concinity

        relabel_configs:
          - source_labels: [__address__]
            target_label: __param_target
          - source_labels: [__param_target]
            target_label: instance
          - target_label: __address__
            replacement: blackbox-prometheus-blackbox-exporter.monitoring.svc.cluster.local:9115

grafana:
  enabled: false

alertmanager:
  alertmanagerSpec: {}

  config:
    global:
      resolve_timeout: 5m
      smtp_smarthost: "smtp.office365.com:587"
      smtp_from: "no-reply@addverb.in"
      smtp_auth_username: "no-reply@addverb.in"
      smtp_auth_password: "REPLACE_WITH_SECRET"
      smtp_require_tls: true

    route:
      receiver: "default-email"
      group_by: ["alertname"]
      group_wait: 30s
      group_interval: 5m
      repeat_interval: 1h
      routes:
        - matchers:
            - alertname="Watchdog"
          receiver: "blackhole"

    receivers:
      - name: "default-email"
        email_configs:
          - to: "shiv.kumar@addverb.com"
            send_resolved: true

      - name: "blackhole"
        webhook_configs: []

    inhibit_rules:
      - source_matchers:
          - severity="critical"
        target_matchers:
          - severity=~"warning|info"
        equal: ["namespace", "alertname"]

      - source_matchers:
          - severity="warning"
        target_matchers:
          - severity="info"
        equal: ["namespace", "alertname"]

      - source_matchers:
          - alertname="InfoInhibitor"
        target_matchers:
          - severity="info"
        equal: ["namespace"]

      - source_matchers:
          - alertname="InfoInhibitor"
        target_matchers: []

prometheus-node-exporter:
  enabled: true
  hostNetwork: true
  hostPID: true

  serviceMonitor:
    enabled: true

  podAnnotations:
    prometheus.io/scrape: "true"
    prometheus.io/port: "9100"          
